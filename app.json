{
  "expo": {
    "name": "prototipoAPPPACO",
    "slug": "prototipoAPPPACO",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/paco/brand/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "paco-showroom",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6F8FF",
        "foregroundImage": "./assets/paco/brand/icon.png",
        "monochromeImage": "./assets/paco/brand/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/paco/brand/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/paco/fonts/Gordita-Bold.otf",
            "./assets/paco/fonts/Lato-Regular.ttf"
          ]
        }
      ]
    ],
    "splash": {
      "image": "./assets/paco/brand/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F8FF"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
